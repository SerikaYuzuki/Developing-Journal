# macOS / editor noise
**/.DS_Store
.vscode/*
!.vscode/settings.json
.idea/

# Claude Code personal settings (must stay local; autosync commits everything untracked)
.claude/settings.local.json

# Python / uv environments and caches
.venv/
venv/
env/
.env/
__pycache__/
*.py[cod]
*$py.class
.python-version.tmp
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# uv cache metadata should live outside this iCloud-synced project.
.uv-cache/

# Jupyter
.jupyter/
.ipynb_checkpoints/
**/.ipynb_checkpoints/
**/*.quarto_ipynb

# Quarto generated state and caches.
# `_site/` is intentionally committed in this repository.
.quarto/
_cache/
_freeze/
*_cache/
*_files/

# Rendered artifacts outside `_site/`. Keep intentional source/reference files explicitly below.
*.html
*.pdf
*.docx
*.odt
*.rtf
*.tex

!_site/**
!_includes/**/*.html
!_reference-docs/**/*.docx

/.quarto/
